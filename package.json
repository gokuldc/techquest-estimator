{
  "name": "openprix",
  "private": true,
  "version": "2.0.0",
  "description": "The Operating System for Modern Engineering & Construction Firms.",
  "author": "Gokul DC",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:client": "npm run build && electron-builder",
    "deploy": "node scripts/deploy.js",
    "preview": "vite preview",
    "electron:start": "electron . --disable-gpu --disable-gpu-compositing",
    "dev:electron": "cross-env NODE_ENV=development concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && npm run electron:start\"",
    "serve": "node server.js"
  },
  "build": {
    "appId": "com.openprix.estimator",
    "productName": "OPENPRIX",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Office",
      "icon": "public/icon.png"
    },
    "deb": {
      "depends": [
        "curl",
        "tar"
      ],
      "afterInstall": "build/linux-post-install.sh"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns",
      "category": "public.app-category.business"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 350,
          "type": "file",
          "path": "Server_Runtime/start-server.command",
          "name": "Launch Server"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "MASTER_DB_SAMPLE.json"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.1",
    "@mui/material": "^6.4.1",
    "better-sqlite3": "^11.8.1",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "cors": "^2.8.6",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "joi": "^17.13.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "systray2": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.4.1",
    "wait-on": "^8.0.2"
  }
}