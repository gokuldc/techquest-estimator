{
  "name": "openprix",
  "private": true,
  "version": "1.9.9",
  "description": "Professional estimation solution for civil engineers.",
  "author": "Gokul DC",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron . --disable-gpu --disable-gpu-compositing",
    "dev:electron": "cross-env NODE_ENV=development concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && npm run electron:start\"",
    "build:electron": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.openprix.estimator",
    "productName": "OPENPRIX",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "MASTER_DB_SAMPLE.json"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.1",
    "@mui/material": "^6.4.1",
    "better-sqlite3": "^12.8.0",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.4.1",
    "wait-on": "^8.0.2"
  }
}